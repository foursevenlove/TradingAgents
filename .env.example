# LLM Providers (set the one you use)
# MiniMax (default for A-share analysis)
MINIMAX_API_KEY=

# Alibaba Bailian (DashScope) - Qwen models
DASHSCOPE_API_KEY=

# Alibaba Cloud Coding Plan - OpenAI-compatible endpoint
ALIYUN_CODING_PLAN_API_KEY=
# Optional aliases also supported:
# CODING_PLAN_API_KEY=

# Other providers
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Tushare Pro (A-share news data source)
TUSHARE_TOKEN=

# ===== Web Configuration =====

# Service port (default 8000)
TRADINGAGENTS_PORT=8000

# CORS allowed origins (comma-separated, required for production)
TRADINGAGENTS_CORS_ORIGINS=https://your-domain.com,http://localhost:3000

# Optional API key for authentication
TRADINGAGENTS_API_KEY=
