# TradingAgents Docker Deployment - Simplified Build
# Assumes frontend is already built locally (web/frontend/dist exists)
# Use this when you have network issues pulling node:alpine image

FROM python:3.11-slim AS backend

# Accept proxy arguments
ARG http_proxy
ARG https_proxy

WORKDIR /app

# Install system dependencies (with proxy if provided)
# Skip curl - use Python for healthcheck instead
RUN if [ -n "$http_proxy" ]; then \
        export http_proxy=$http_proxy https_proxy=$https_proxy && \
        apt-get update; \
    else \
        apt-get update; \
    fi && rm -rf /var/lib/apt/lists/*

# Copy requirements first for better caching
COPY requirements.txt pyproject.toml ./

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY tradingagents/ ./tradingagents/
COPY cli/ ./cli/
COPY web/backend/ ./web/backend/
COPY main.py analyze.py ./

# Copy frontend build from local (assumes web/frontend/dist exists)
COPY web/frontend/dist ./web/frontend/dist

# Create necessary directories
RUN mkdir -p /app/logs /app/reports /app/results

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV TRADINGAGENTS_WEB_HOST=0.0.0.0
ENV TRADINGAGENTS_WEB_PORT=8000

# Expose port
EXPOSE 8000

# Health check (using Python instead of curl)
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')" || exit 1

# Run the application
CMD ["uvicorn", "web.backend.app:app", "--host", "0.0.0.0", "--port", "8000"]