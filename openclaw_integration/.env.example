# Telegram Bot 配置
# 从 @BotFather 获取
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# 你的 Telegram Chat ID
# 访问 https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates 获取
TELEGRAM_CHAT_ID=123456789

# API 服务端口（可选，默认 5000）
PORT=5000

# MiniMax API Key（用于股票分析）
MINIMAX_API_KEY=your_minimax_api_key_here
